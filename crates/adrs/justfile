# Test: search command
[unix]
test-search: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    $ADRS init > /dev/null
    $ADRS new --no-edit "Use PostgreSQL for database" > /dev/null
    $ADRS new --no-edit "Use Redis for caching" > /dev/null
    echo "Testing: adrs search postgres"
    $ADRS search postgres
    echo "---"
    echo "Testing: adrs search -t database"
    $ADRS search -t database

# Test: link and status commands
[unix]
test-link-status: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    $ADRS init > /dev/null
    $ADRS new --no-edit "First" > /dev/null
    $ADRS new --no-edit "Second" > /dev/null
    echo "Testing: adrs status 2 accepted"
    $ADRS status 2 accepted
    echo "---"
    echo "Testing: adrs link 2 'Amends' 3"
    $ADRS link 2 "Amends" 3
    echo "---"
    echo "ADR 2 after changes:"
    cat doc/adr/0002-first.md
    echo "---"
    echo "ADR 3 after changes:"
    cat doc/adr/0003-second.md

