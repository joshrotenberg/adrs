# Test: init command
[unix]
test-init: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    echo "Testing: adrs init"
    $ADRS init
    echo "---"
    ls -la doc/adr/

# Test: init with custom directory
[unix]
test-init-custom: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    echo "Testing: adrs init decisions"
    $ADRS init decisions
    echo "---"
    ls -la decisions/

# Test: new command
[unix]
test-new: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    $ADRS init > /dev/null
    echo "Testing: adrs new --no-edit 'Use Rust'"
    $ADRS new --no-edit "Use Rust"
    echo "---"
    cat doc/adr/0002-use-rust.md

