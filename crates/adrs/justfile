# Test: export/import
[unix]
test-export-import: build
    #!/usr/bin/env bash
    set -euo pipefail
    ADRS="$(pwd)/{{adrs_bin}}"
    DIR=$(mktemp -d) && trap "rm -rf $DIR" EXIT && cd "$DIR"
    $ADRS init > /dev/null
    $ADRS new --no-edit "Test" > /dev/null
    echo "Testing: adrs export json --pretty"
    $ADRS export json --pretty
    echo "---"
    echo "Exporting to file and reimporting..."
    $ADRS export json > export.json
    mkdir import-test && cd import-test
    $ADRS import json --dir . ../export.json --dry-run

