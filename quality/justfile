# quality/justfile - Code quality, security, and coverage recipes
# See ADR-0014 for justfile conventions

set working-directory := ".."

# ============================================================================
# Quality Recipes
# ============================================================================

# Run quality checks (coverage, security, unused, outdated, all)
[default]
check choice="all":
    @case "{{ choice }}" in \
        coverage) just quality::coverage ;; \
        security) just quality::security ;; \
        unused) just quality::unused ;; \
        outdated) just quality::outdated ;; \
        all) just quality::all ;; \
        *) echo "Unknown: {{ choice }}. Options: coverage, security, unused, outdated, all" && exit 1 ;; \
    esac

# ============================================================================
# Coverage
# ============================================================================

# Generate coverage report (HTML)
coverage:
    cargo llvm-cov clean --workspace
    cargo llvm-cov --no-report --package adrs-core
    cargo llvm-cov --no-report --doc --package adrs-core
    cargo llvm-cov report --package adrs-core --html
    @echo "Report: target/llvm-cov/html/index.html"

# Generate doctest-only coverage
coverage-doc:
    cargo llvm-cov --doc --package adrs-core --html --open

# Coverage with text summary
coverage-text:
    cargo llvm-cov clean --workspace
    cargo llvm-cov --no-report --package adrs-core
    cargo llvm-cov --no-report --doc --package adrs-core
    cargo llvm-cov report --package adrs-core --text

# ============================================================================
# Security
# ============================================================================

# Run cargo-deny checks (includes security audit)
deny:
    cargo deny check

# Full security check
security: deny
    @echo "Security checks passed!"

# ============================================================================
# Maintenance
# ============================================================================

# Check for unused dependencies
unused:
    cargo machete

# Check for outdated dependencies
outdated:
    cargo outdated -R

# ============================================================================
# Full Quality
# ============================================================================

# Full quality check (use before committing)
all: security unused
    cargo fmt --check
    cargo clippy --all-targets --all-features -- -D warnings
    @echo "All quality checks passed!"
